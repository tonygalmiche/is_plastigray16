<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Bases de données -->
        <record id="is_database_form_view" model="ir.ui.view">
            <field name="name">is_database_form_view</field>
            <field name="model">is.database</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name='name' />
                                <field name='standard_telephonique'/>
                            </group>
                            <group groups="base.group_system">
                                <field name='ip_server' />
                                <field name='database' />
                                <field name='port_server' />
                                <field name='login' />
                                <field name='password' password='True' />
                            </group>
                        </group>
                        <group>
                            <field name="preventif_equipement_user_ids" widget="many2many_tags"/>
                            <field name="moyen_controle_user_ids" widget="many2many_tags"/>
                            <field name="directeur_site_ids" widget="many2many_tags"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
        <record id="is_database_tree_view" model="ir.ui.view">
            <field name="name">is_database_tree_view</field>
            <field name="model">is.database</field>
            <field name="arch" type="xml">
                <tree>
                    <field name='name' />
                    <field name='standard_telephonique'/>
                    <field name='ip_server' groups="base.group_system" optional="show"/>
                    <field name='port_server' groups="base.group_system" optional="show"/>
                    <field name='database' groups="base.group_system" optional="show"/>
                    <field name='login' groups="base.group_system" optional="show"/>
                    <field name='standard_telephonique' optional="show"/>
                    <field name="preventif_equipement_user_ids" widget="many2many_tags" optional="show"/>
                    <field name="moyen_controle_user_ids" widget="many2many_tags" optional="show"/>
                    <field name="directeur_site_ids" widget="many2many_tags" optional="show"/>
                    <field name='is_database_origine_id' optional="hide" />

                </tree>
            </field>
        </record>
        <record id="is_database_action" model="ir.actions.act_window">
            <field name="name">Site</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">is.database</field>
            <field name="view_mode">tree,form</field>
        </record>
    </data>
</odoo>
